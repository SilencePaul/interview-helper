# Environment: "dev" (default) or "prod"
# dev  — uses MockLLM, no real API calls
# prod — uses real Anthropic API (ANTHROPIC_API_KEY required)
APP_ENV=dev

# Anthropic API Key (required only in prod mode)
ANTHROPIC_API_KEY=sk-ant-...

# Model selection (optional – defaults shown)
MODEL_TUTOR=claude-sonnet-4-6
MODEL_INTERVIEWER=claude-sonnet-4-6
MODEL_GRADER=claude-sonnet-4-6
MODEL_FIGURES=claude-haiku-4-5-20251001
